#!/bin/bash
#
# Generate Sysdump
# creates a snapshot of system state for debugging later.
#

set -u

trap 'handle_signal' HUP INT QUIT TERM KILL ABRT ALRM

source /usr/bin/logrotate-utils.sh

TRACKPROGRESS=false
update_db_state()
{
    if [ ! $TRACKPROGRESS ] ; then
        return
    fi
    outpfl=${2:+output-filename $2}
    timelogfl=${3:+timeinfo-filename $3}
    /usr/local/bin/sonic-db-cli STATE_DB hmset "SHOW_TECHSUPPORT|GLOBAL" progress-state "${1}" ${outpfl} ${timelogfl} > /dev/null
    update_index_list "$1"
}

TS_INDEX_CNT=0
update_index_list()
{
    if [ ! -e $TECHSUPPORT_INDEX_INFO ] ; then
        if [ "${1}" == "Starting" ] ; then
           echo "#${1}" > $TECHSUPPORT_INDEX_INFO
        fi
        # else (not Starting) is post cleanup
        return
    fi
    tar tf $TARFILE > ${TECHSUPPORT_INDEX_INFO}_new
    tail +$TS_INDEX_CNT ${TECHSUPPORT_INDEX_INFO}_new >> $TECHSUPPORT_INDEX_INFO
    TS_INDEX_CNT=$((`wc -l < ${TECHSUPPORT_INDEX_INFO}_new` + 1))
    rm ${TECHSUPPORT_INDEX_INFO}_new
    echo "#${1}" >> $TECHSUPPORT_INDEX_INFO
}

cleanup_dump_files(){

    if [[ ! -e /var/dump ]]; then
        return
    fi

    # Clean up the older techsupport files
    DCNT=5
    LOG_SIZE_MB=$(df -m /var/log |awk 'NR==2{print int($2)}')
    if [[ ${LOG_SIZE_MB} -lt 1024 ]]; then
        DCNT=2
    fi

    # Clean up the older techsupport gz files 
    find /var/dump/* -name 'sonic_dump_*.tar.gz' -printf "%T+ %p\n"|sort -nr|awk 'NR>'${DCNT}'{print $2}'|xargs -I{} rm -f "{}"

    # Clean up the uncleaned directories and tar files if it stays for more than 60 minutes
    find /var/dump/* -name 'sonic_dump_*.tar' -mmin +60 -printf "%T+ %p\n"|sort -nr|awk '{print $2}'|xargs -I{} rm -f "{}"
    find /var/dump/* -type d -name "sonic_dump_*" -mmin +60 -exec rm -rf "{}" \;
}

cleanup_tmpfiles() {
    if [ -e $TARDIR ] ; then
        rm $V -rf $TARDIR
    fi
    if [ -e $TECHSUPPORT_TIME_INFO ] ; then
        rm $V -rf $TECHSUPPORT_TIME_INFO
    fi
    if [ -e $TECHSUPPORT_INDEX_INFO ] ; then
        rm $V -rf $TECHSUPPORT_INDEX_INFO
    fi
    if [ -e $TECHSUPPORT_INDEX_FILE ] ; then
        rm $V -rf $TECHSUPPORT_INDEX_FILE
    fi
    if [ -e $TECHSUPPORT_SAVE_PROC_INFO ] ; then
        rm $V -rf $TECHSUPPORT_SAVE_PROC_INFO
    fi
    if [ -e $REFERENCE_FILE ] ; then
        rm $V -rf $REFERENCE_FILE
    fi

    # Clean up the /var/dump files
    cleanup_dump_files

}

handle_signal()
{
    echo "Generate Dump received interrupt"
    if [ -e /var/run/techsupport.inprogress ] ; then
	   enable_logrotate
    fi
    cleanup_tmpfiles
    rm $V -rf $TARFILE
    update_db_state Canceled
    sync
    exit 1
}

ERROR_TAR_FAILED=5
ERROR_PROCFS_SAVE_FAILED=6
ERROR_INVALID_ARGUMENT=10

