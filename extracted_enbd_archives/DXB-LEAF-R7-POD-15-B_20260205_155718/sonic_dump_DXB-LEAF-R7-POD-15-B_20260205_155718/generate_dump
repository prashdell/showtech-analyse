###############################################################################
# disable_logrotate routine
# Globals:
#  None
# Arguments:
#  None
# Returns:
#  None
###############################################################################
disable_logrotate() {
	
	#Flush the in-memory logs forcefully to disk
	logger -p NOTICE "Running show techsupport"
	/usr/bin/in-memory.sh --force --rotate-log-all

    sync; sync
	#Inform in-memory to stop flushing logs to disk
	touch /var/run/techsupport.inprogress
	
	logrotate_deactivate
}

###############################################################################
# enable_logrotate routine
# Globals:
#  None
# Arguments:
#  None
# Returns:
#  None
###############################################################################
enable_logrotate() {
	
	logrotate_activate

	#Inform in-memory to resume flushing logs to disk
	rm -f /var/run/techsupport.inprogress

	#Trigger the auto log rotate
	touch /var/log/rotate/disk/syslog 
}


