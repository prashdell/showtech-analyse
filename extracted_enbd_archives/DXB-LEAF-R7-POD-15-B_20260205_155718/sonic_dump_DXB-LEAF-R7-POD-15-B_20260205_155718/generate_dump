dump_mgmt_service_profiles()
{
    docker exec mgmt-framework supervisorctl signal USR1 rest-server
    docker exec telemetry supervisorctl signal USR1 telemetry
}

collect_mgmt_service_logs() {
    local container=$1
    local program=$2
    if [[ -z $(docker container ls -aqf name=${container}) ]]; then
        return
    fi
    # Copy logs from container to temp dir
    local tmpDir=$(mktemp -d)
    docker cp -a ${container}:/var/log/${program} ${tmpDir}
    # Prefix program name to profile dump filenames to avoid confusion
    for f in ${tmpDir}/${program}/*pprof*; do
        mv $f ${tmpDir}/${program}/${program}_$(basename $f)
    done
    # Save to log directory of the dump
    for f in ${tmpDir}/${program}/*; do
        save_file $f log true
    done
    $RM $V -rf ${tmpDir}
}

###############################################################################
# Main generate_dump routine
# Globals:
#  All of them.
# Arguments:
#  None
# Returns:
#  None
###############################################################################
main() {
    local start_t=0
    local end_t=0
    local total_t=$(date +%s)
    if [ `whoami` != root ] && ! $NOOP;
    then
        echo "$0: must be run as root (or in sudo)" >&2
        cleanup_tmpfiles
        rm $V -rf $TARFILE
        update_db_state Exited
        sync
        exit 10
    fi
    NUM_ASICS=$(get_asic_count)
    ${CMD_PREFIX}renice +5 -p $$ >> /dev/null
    ${CMD_PREFIX}ionice -c 2 -n 5 -p $$ >> /dev/null

    $MKDIR $V -p $TARDIR

    # Start with this script so its obvious what code is responsible
    $LN $V -s /usr/local/bin/generate_dump $TARDIR
    $TAR $V -chf $TARFILE -C $DUMPDIR $BASE
    $RM $V -f $TARDIR/sonic_dump

    # General file for all the klish commands
    TS_KLISH_CMDS=$(prepare_klish_cmd_group)

    $TOUCH $TECHSUPPORT_TIME_INFO
    $TOUCH $TECHSUPPORT_SAVE_PROC_INFO
    # if old data is present clear it
    echo $BASE > $TECHSUPPORT_TIME_INFO
    start_t=$(date +%s%3N)

    # Capture /proc state early
    update_db_state "Collecting System proc info"
    save_proc /proc/buddyinfo /proc/cmdline /proc/consoles \
        /proc/cpuinfo /proc/devices /proc/diskstats /proc/dma \
        /proc/interrupts /proc/iomem /proc/ioports /proc/kallsyms \
        /proc/loadavg /proc/locks /proc/meminfo /proc/misc \
        /proc/modules /proc/self/mounts \
        /proc/pagetypeinfo /proc/partitions /proc/sched_debug /proc/slabinfo \
        /proc/softirqs /proc/stat /proc/swaps /proc/sysvipc /proc/timer_list \
        /proc/uptime /proc/version /proc/vmallocinfo /proc/vmstat \
        /proc/zoneinfo \
        || echo "${ERROR_PROCFS_SAVE_FAILED} Proc saving operation failed. Aborting  for safety." >> $TECHSUPPORT_SAVE_PROC_INFO

    save_proc_net
    end_t=$(date +%s%3N)
    echo "[ Capture Proc State ] : $(($end_t-$start_t)) msec" >> $TECHSUPPORT_TIME_INFO

    # Signal rest_server and telemetry processes to dump their profile data (cpu, heap, goroutine).
    # They will be collected later along with other log files. Do this early to avoid skews
    # due to the commands run by this script itself.
    dump_mgmt_service_profiles

    # Save techsupport save proc info log
    save_file $TECHSUPPORT_SAVE_PROC_INFO log false

    # Save all the processes within each docker
    update_db_state "Collecting Application processes info"
    save_cmd "show services" services.summary

    # Save reboot cause information
    save_cmd "show reboot-cause" reboot.cause

    update_db_state "Collecting Counters-1"
    # Need 2 snapshots to make sense of counters trend. First snapshot early.
    counter_t=$(date +'%d/%m/%Y %H:%M:%S:%6N')
    save_cmd "echo $counter_t" "date.counter_1"
    save_cmd "show interface counters" "interface.counters_1"
    save_cmd "docker exec -it bgp /usr/xdp/sample/xdp-counter BFDRX XF_BFD" "bfd_xdp_counters_1"
    save_cmd "docker exec -it bgp /usr/xdp/sample/xdp-stats XF_BFD" "bfd_xdp_stats_1"
