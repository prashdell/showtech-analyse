###############################################################################
# save_history_file routine to convert history file containing unix timestamp
#       to human readable date and then save the file.
# Globals:
#  None
# Arguments:
#  - history file with unix timestamps
#  - output file
# Returns:
#  None
###############################################################################
save_history_file() {
    local input=$1
    local output=$2
    local output_file="/home/admin/${output}"
    awk -F\# '/^#1[0-9]{9}$/ {
        if(cmd)
            printf "%s %s\n",ts,cmd;
            ts=strftime("%b %d %y %T",$2); cmd="";
    } !/^#1[0-9]{9}$/ {
        if(cmd)
            cmd=cmd "\n" $0;
        else
            cmd=$0
    }' $input > $output_file
    save_cmd "cat ${output_file}" $output
    rm -f $output_file
}

