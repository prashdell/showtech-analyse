    save_cmd "docker exec -it udld /usr/xdp/sample/xdp-stats XF_UDLD" "udld_xdp_stats_1"
    save_cmd "show queue counters" "queue.counters_1" 
    save_cmd "show interface pktdrops nonzero" "interface.pktdrops_1"
    save_cmd "show vxlan counters" "vxlan.counters_1"
    save_cmd "ras-mc-ctl --errors" "ras-mc-ctl-errors.summary"
    debugsh_dump copp_counters1 orchagent
