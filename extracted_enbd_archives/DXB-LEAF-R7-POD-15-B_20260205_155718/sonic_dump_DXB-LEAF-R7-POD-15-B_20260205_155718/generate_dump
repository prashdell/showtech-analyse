###############################################################################
# Save log file
# Globals:
#  None
# Arguments:
#  None
# Returns:
#  None
###############################################################################
save_log_files() {
    disable_logrotate

    start_t=$(date +%s%3N)

    #save details of log files present in var log
    save_cmd "ls -ltrR /var/log" "var_log_files"

    # Copy ONIE update log always
    if [ -f "/var/log/onie-update.log" ]; then
        save_file "/var/log/onie-update.log" log true false
    fi

    save_dir "/var/log/audit" log

    # gzip up all log files individually before placing them in the incremental tarball
    for file in $(find_files "/var/log/"); do
        # ignore the sparse file lastlog
        if [ "$file" = "/var/log/lastlog" ]; then
            continue
        fi

        # ignore system journal as they are copied separately
        if echo $file | grep -q "/var/log/journal"; then
            continue
        fi

        # Skip the in-memory and auto-logrotate trigger log files
        if [[ -z ${file/*ramfs*/} || -z ${file/*rotate*/} ]]; then
            continue
        fi

        # ignore ONIE update log as it is copied separately
        if echo $file | grep -q "/var/log/onie-update.log"; then
            continue
        fi

        # Skip kernel audit logs as they are copied separately
        if echo $file | grep -q "/var/log/audit/"; then
            continue
        fi

        # don't gzip already-gzipped log files :)
        if [ -z "${file##*.gz}" ]; then
            save_file $file log false false
        else
            save_file $file log true false
        fi
    done

    # Append the log folder from the dumpdir to the main tarball
    ($TAR $V -rhf $TARFILE -C $DUMPDIR ${BASE}/log \
        || abort "${ERROR_TAR_FAILED}" "tar append operation failed. Aborting for safety") \
        && $RM $V -rf $TARDIR/log
    end_t=$(date +%s%3N)
    echo "[ TAR /var/log Files ] : $(($end_t-$start_t)) msec" >> $TECHSUPPORT_TIME_INFO

    enable_logrotate
}

