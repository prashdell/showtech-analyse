#
# This file MUST be edited with the 'visudo' command as root.
#
# Please consider adding local content in /etc/sudoers.d/ instead of
# directly modifying this file.
#
# See the man page for details on how to write a sudoers file.
#
Defaults        env_reset
#Defaults        mail_badpass
Defaults        secure_path="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

Defaults        env_keep += "SONIC_CLI_IFACE_MODE"
Defaults        env_keep += "VTYSH_PAGER"
Defaults        lecture_file = /etc/sudoers.lecture

# Host alias specification

# User alias specification

# Cmnd alias specification
# Note: bcmcmd is dangerous for users in read only netgroups because it may operate ASIC
Cmnd_Alias      READ_ONLY_CMDS = /sbin/brctl show, \
                                 /usr/bin/docker images *, \
                                 /usr/bin/docker exec snmp cat /etc/snmp/snmpd.conf, \
                                 /usr/bin/docker exec bgp cat /etc/quagga/bgpd.conf, \
/usr/bin/docker exec database ps aux, \
/usr/bin/docker exec eventd ps aux, \
/usr/bin/docker exec bgp ps aux, \
/usr/bin/docker exec iccpd ps aux, \
/usr/bin/docker exec l2mcd ps aux, \
/usr/bin/docker exec lldp ps aux, \
/usr/bin/docker exec mfa ps aux, \
/usr/bin/docker exec nat ps aux, \
/usr/bin/docker exec pmon ps aux, \
/usr/bin/docker exec radv ps aux, \
/usr/bin/docker exec sflow ps aux, \
/usr/bin/docker exec snmp ps aux, \
/usr/bin/docker exec mgmt-framework ps aux, \
/usr/bin/docker exec stp ps aux, \
/usr/bin/docker exec tam ps aux, \
/usr/bin/docker exec teamd ps aux, \
/usr/bin/docker exec telemetry ps aux, \
/usr/bin/docker exec timesync ps aux, \
/usr/bin/docker exec udld ps aux, \
/usr/bin/docker exec vrrp ps aux, \
/usr/bin/docker exec gbsyncd ps aux, \
/usr/bin/docker exec swss ps aux, \
/usr/bin/docker exec syncd ps aux, \
/usr/bin/docker exec dhcp_relay ps aux, \
/usr/bin/docker ps*, \
                                 /usr/local/sbin/show *, \
                                 /usr/local/bin/sonic-db-cli STATE_DB hget DEVICE_METADATA_STATE|localhost intf_naming_mode, \
                                 /usr/local/bin/generate_dump, \
                                 /usr/local/bin/clear_dump, \
                                 /usr/bin/lldpctl, \
                                 /usr/bin/sensors, \
                                 /usr/bin/vtysh -c show *, \
                                 /usr/bin/vtysh -n [0-9] -c show *, \
                                 /usr/local/bin/decode-syseeprom, \
                                 /usr/local/bin/lldpshow, \
                                 /usr/local/bin/psuutil *, \
                                 /usr/local/bin/sonic-installer list, \
                                 /usr/local/bin/sfputil show *, \
                                 /bin/cat /var/log/syslog, \
                                 /bin/cat /var/log/syslog.1, \
                                 /bin/cat /var/log/syslog.1 /var/log/syslog, \
                                 /usr/bin/tail -F /var/log/syslog

Cmnd_Alias      PASSWD_CMDS = /usr/local/bin/config tacacs passkey *, \
                              /usr/sbin/chpasswd *

# User privilege specification
root    ALL=(ALL:ALL) ALL

# Allow all users to execute read only commands
ALL     ALL=NOPASSWD: READ_ONLY_CMDS

# Allow members of group sudo to execute any command
%sudo   ALL=(ALL:ALL) NOPASSWD: ALL

# Prevent password related command into syslog
Defaults!PASSWD_CMDS !syslog

# See sudoers(5) for more information on "#include" directives:

#includedir /etc/sudoers.d

