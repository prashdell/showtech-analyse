_show_completion() {
    ORG_PATH=${PATH}
    PATH=/usr/bin:${PATH}
    COMPREPLY=( $( env COMP_WORDS="${COMP_WORDS[*]}" \
                   COMP_CWORD=$COMP_CWORD \
                   _SHOW_COMPLETE=complete $1 ) )
    PATH=${ORG_PATH}
    return 0
}

complete -F _show_completion -o default show;
