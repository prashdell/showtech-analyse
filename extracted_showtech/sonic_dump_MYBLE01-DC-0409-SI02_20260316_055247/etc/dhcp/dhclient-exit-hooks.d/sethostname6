PYTHON_PATH=/usr/bin/python3
SCRIPT=/usr/bin/dhcp_config_update.py
IF_NAME=$interface

dhcp_hostname_handle() {
case $reason in
    BOUND6|RENEW6|REBIND6|REBOOT)
        current_dhcp6_fqdn=`hostname`
        if [ "$current_dhcp6_fqdn" != "$new_dhcp6_fqdn" ] && [ -n "$new_dhcp6_fqdn" ]
        then
            $PYTHON_PATH $SCRIPT add dhcp6 $IF_NAME hostname $new_dhcp6_fqdn
        fi
        ;;
    EXPIRE6|FAIL|RELEASE6|STOP)
        #For deletion hostname is not required,
        #hence empty string is passed
        $PYTHON_PATH $SCRIPT del dhcp6 $IF_NAME hostname ""
esac
}

dhcp_hostname_handle
