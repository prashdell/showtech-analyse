PYTHON_PATH=/usr/bin/python3
SCRIPT=/usr/bin/dhcp_config_update.py
IF_NAME=$interface

dhcp_hostname_handle() {
case $reason in
    BOUND|RENEW|REBIND|REBOOT)
        current_host_name=`hostname -s`
        if [ "$current_host_name" != "$new_host_name" ] && [ -n "$new_host_name" ]
        then
            $PYTHON_PATH $SCRIPT add dhcp4 $IF_NAME hostname $new_host_name
        fi
        ;;
    EXPIRE|FAIL|RELEASE|STOP)
        #For deletion hostname is not required,
        #hence empty string is passed
        $PYTHON_PATH $SCRIPT del dhcp4 $IF_NAME hostname ""
esac
}

dhcp_hostname_handle
