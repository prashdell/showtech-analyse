# Render the config_db.json.j2 template if defined
CONFIG_PROFILES_BASE=/usr/share/broadcom_sonic/config_profiles
PLATFORM=`sonic-cfggen -H -v DEVICE_METADATA.localhost.platform`
PRESET=(`head -n 1 /usr/share/sonic/device/$PLATFORM/default_sku`)
HW_KEY=${PRESET[0]}
CONFIG_DB_JSON="/etc/sonic/config_db.json"
ROCE_QOS_CONFIG_TEMPLATE="/usr/share/sonic/templates/roce_qos_config.j2"
ROCE_BUFFERS_CONFIG_TEMPLATE="/usr/share/sonic/templates/roce_buffers_config.j2"
ROCE_QOS_JSON="/tmp/roce_qos_config.json"
ROCE_BUFFERS_JSON="/tmp/roce_buffers_config.json"
ROCE_JSON="/tmp/roce_config.json"
BASE_CONFIG_DB_JSON="/tmp/base_config_db.json"

# Generate ROCE config based on product_class and feature
function render_roce_config()
{
    if [[ -f ${ROCE_QOS_CONFIG_TEMPLATE} && -f ${ROCE_BUFFERS_CONFIG_TEMPLATE} ]]; then
        force_intf_naming_mode=native sonic-cfggen -H -k ${HW_KEY} -t ${ROCE_QOS_CONFIG_TEMPLATE} -p \
                    -y /etc/sonic/sonic_branding.yml > ${ROCE_QOS_JSON}
        force_intf_naming_mode=native sonic-cfggen -H -k ${HW_KEY} -t ${ROCE_BUFFERS_CONFIG_TEMPLATE} -p \
                    -y /etc/sonic/sonic_branding.yml > ${ROCE_BUFFERS_JSON}
        if [[ -f ${ROCE_QOS_JSON} && -f ${ROCE_BUFFERS_JSON} ]]; then
            jq --indent 4 -s '.[0] + .[1]' ${ROCE_QOS_JSON} ${ROCE_BUFFERS_JSON} > ${ROCE_JSON}
        fi
    fi
}

# Merge BASE config with ROCE config
function merge_base_and_roce_config()
{
    if [[ -f ${ROCE_JSON} && -f ${BASE_CONFIG_DB_JSON} ]]; then
        jq --indent 4 -s '.[0] + .[1]' ${BASE_CONFIG_DB_JSON} ${ROCE_JSON} > ${CONFIG_DB_JSON}
    else
        cp ${BASE_CONFIG_DB_JSON} ${CONFIG_DB_JSON}
    fi
}

function render_config_db()
{
    if [ -d ${CONFIG_PROFILES_BASE} ]; then
        ACTIVE_PROFILE_FLAG=${CONFIG_PROFILES_BASE}/active
        CONFIG_DB_TEMPLATE=${CONFIG_PROFILES_BASE}/$(cat ${ACTIVE_PROFILE_FLAG})/templates/config_db.json.j2
        DATA_DIR=${CONFIG_PROFILES_BASE}/$(cat ${ACTIVE_PROFILE_FLAG})/data

        if [ -f ${CONFIG_DB_TEMPLATE} ] && [ "${HW_KEY}" != "" ]; then
            force_intf_naming_mode=native sonic-cfggen -H -k ${HW_KEY} -j ${DATA_DIR}/features.json -p \
                         -y /etc/sonic/sonic_branding.yml \
                         -y /etc/sonic/hw_resources/plat_chip_info.yaml \
                         -t ${CONFIG_DB_TEMPLATE} \
                         > ${BASE_CONFIG_DB_JSON}
            render_roce_config
            merge_base_and_roce_config
            exit_status=$rv
            if [ -e ${CONFIG_DB_JSON} ]; then
                if [ -x /usr/local/bin/db_migrator.py ]; then
                    /usr/local/bin/db_migrator.py -o update_version
                fi
            fi
        else
            exit_status=1
        fi
    fi
}

render_config_db
