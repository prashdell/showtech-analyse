
# Keep the count as 29 by default
# Make it to 14 for low-end devices in runtime
/var/log/histogram/mem-histogram.log.gz
/var/log/histogram/mem-histogram-total.log.gz
{
    rotate 29
    missingok
    notifempty
    sharedscripts
    create
    postrotate
        systemctl kill --kill-who=main --signal=HUP rsyslog
    endscript
}

