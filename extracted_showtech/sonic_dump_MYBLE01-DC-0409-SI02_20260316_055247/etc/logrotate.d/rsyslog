/var/log/swss/sairedis.rec
/var/log/swss/swss.rec
/var/log/nbrmgrd.log
{
    size 5M
    rotate 800
    missingok
    notifempty
    compress
    delaycompress
    nosharedscripts
    postrotate
        if [ $(echo $1 | grep -c "/var/log/swss/") -gt 0 ]; then
            pgrep -x orchagent | xargs /bin/kill -HUP 2>/dev/null || true
        else
            systemctl kill --kill-who=main --signal=HUP rsyslog
        fi
    endscript
}

