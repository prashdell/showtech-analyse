[Unit]
Description=sFlow container
Requisite=swss.service
After=swss.service syncd.service hostcfgd.service portinitdone.service
BindsTo=sonic.target
After=sonic.target
Before=ntp-config.service
StartLimitIntervalSec=1200
StartLimitBurst=20

[Service]
User=admin
ExecStartPre=/usr/bin/sflow.sh start
ExecStart=/usr/bin/sflow.sh wait
ExecStop=/usr/bin/sflow.sh stop
Restart=always
RestartSec=30

[Install]
WantedBy=sonic.target swss.service
