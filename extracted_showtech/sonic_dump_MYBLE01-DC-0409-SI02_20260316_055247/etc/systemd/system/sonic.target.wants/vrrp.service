[Unit]
Description=VRRP container
Requires=updategraph.service database.service
After=updategraph.service portinitdone.service
BindsTo=sonic.target
After=sonic.target
Before=ntp-config.service
StartLimitIntervalSec=1200
StartLimitBurst=20

[Service]
User=admin
ExecStartPre=/usr/bin/vrrp.sh start
ExecStart=/usr/bin/vrrp.sh wait
ExecStop=/usr/bin/vrrp.sh stop
Restart=always
RestartSec=30

[Install]
WantedBy=sonic.target
