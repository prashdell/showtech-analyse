[Unit]
Description=MFA container
Requires=database.service updategraph.service
After=updategraph.service hostcfgd.service
BindsTo=sonic.target
After=sonic.target
Before=ntp-config.service
StartLimitIntervalSec=1200
StartLimitBurst=20
ConditionPathExists=/etc/sonic/mfa/ciam/ciam.config

[Service]
User=admin
ExecStartPre=/usr/bin/mfa.sh start
ExecStart=/usr/bin/mfa.sh wait
ExecStop=/usr/bin/mfa.sh stop
Restart=always
RestartSec=30

[Install]
WantedBy=sonic.target
