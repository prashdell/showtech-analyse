[Unit]
Description=Management Framework container
Requires=updategraph.service database.service
After=updategraph.service database.service
BindsTo=sonic.target
After=sonic.target
Before=ntp-config.service
StartLimitIntervalSec=1200
StartLimitBurst=20

[Service]
User=admin
ExecStartPre=/usr/bin/mgmt-framework.sh start
ExecStart=/usr/bin/mgmt-framework.sh wait
ExecStop=/usr/bin/mgmt-framework.sh stop
Restart=always
RestartSec=30
TimeoutStartSec=480

[Install]
WantedBy=sonic.target
