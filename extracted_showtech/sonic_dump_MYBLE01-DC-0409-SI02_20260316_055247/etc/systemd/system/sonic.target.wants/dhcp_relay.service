[Unit]
Description=DHCP relay container
Requires=updategraph.service
After=portinitdone.service
BindsTo=sonic.target
After=sonic.target
Before=ntp-config.service
StartLimitIntervalSec=1200
StartLimitBurst=20

[Service]
User=admin
ExecStartPre=/usr/bin/dhcp_relay.sh start
ExecStart=/usr/bin/dhcp_relay.sh wait
ExecStop=/usr/bin/dhcp_relay.sh stop
Restart=always
RestartSec=30

[Install]
WantedBy=sonic.target
