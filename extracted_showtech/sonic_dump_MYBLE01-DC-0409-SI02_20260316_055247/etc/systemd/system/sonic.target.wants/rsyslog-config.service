[Unit]
Description=Update rsyslog configuration
Requires=updategraph.service
After=updategraph.service
BindsTo=sonic.target
After=sonic.target
StartLimitIntervalSec=1200
StartLimitBurst=25

[Service]
Type=simple
ExecStart=/usr/bin/rsyslog-config.py
Restart=always
RestartSec=0

[Install]
WantedBy=sonic.target
